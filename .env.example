# Apiary configuration — copy to .env and fill in.
# Nothing here is required to start the app; you add keys as you hire agents.

# Anthropic API key — powers the "Anthropic API" engine (office roles) and the
# planner that breaks orders into tasks. Paste your key to bring the hive to life.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Where the local SQLite database lives. Created automatically on first run.
APIARY_DB_PATH=./data/apiary.db

# How often (in seconds) each worker bee wakes up to check its task queue.
APIARY_HEARTBEAT_SECONDS=15
